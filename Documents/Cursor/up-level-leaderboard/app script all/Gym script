 */
function syncAllHistoryToWeb() {
  const props = PropertiesService.getScriptProperties();
  const processedFiles = JSON.parse(props.getProperty('PROCESSED_FILES') || '[]');
  
  console.log(`📝 ประวัติการทำงาน: ทำเสร็จไปแล้ว ${processedFiles.length} ไฟล์ทั่วโลก`);
  console.log("💡 คำแนะนำ: ถ้าอยากเริ่มใหม่ทั้งหมด ให้กด Run ฟังก์ชัน 'clearSyncHistory' ก่อนนะครับ");
  console.log("🔍 กำลังค้นหาไฟล์ Google Sheet ที่เป็น Form Response ทั้งหมด...");
  
  const files = DriveApp.searchFiles("mimeType = 'application/vnd.google-apps.spreadsheet' and (title contains '(Responses)' or title contains '(การตอบแบบฟอร์ม)') and trashed = false");
  
  let successCount = 0;
  let skipCount = 0;

  while (files.hasNext()) {
    const file = files.next();
    const fileId = file.getId();

    if (processedFiles.includes(fileId)) {
      skipCount++;
      continue;
    }

    console.log(`📂 [NEW] กำลังประมวลผลไฟล์: ${file.getName()}`);

    try {
      const ss = SpreadsheetApp.openById(fileId);
      const sheets = ss.getSheets();
      let syncedInFile = 0;
      let hasError = false;

      sheets.forEach(sheet => {
          try {
            const count = processSheet(sheet);
            syncedInFile += count;
          } catch (err) {
            console.error(`   ❌ Error ชีท ${sheet.getName()}: ${err.toString()}`);
            hasError = true;
          }
      });

      // ✅ บันทึก Checkpoint เฉพาะถ้าส่งข้อมูลสำเร็จ (มากกว่า 0) หรือถ้าไม่มี Error
