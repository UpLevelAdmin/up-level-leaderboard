  if (data.length < 2) return 0;

  const header = data[0];
  // console.log("   Headers: " + JSON.stringify(header)); // Debug ดู Header

  let colPhone = -1, colName = -1, colSlip = -1, colTimestamp = 0;

  // 🔍 Smart Search Columns
  header.forEach((h, i) => {
    const text = String(h).toLowerCase();
    // หา Phone
    if (text.includes("เบอร์") || text.includes("phone") || text.includes("tel") || text.includes("mobile") || text.includes("ติดต่อ")) colPhone = i;
    // หา Name
    else if (text.includes("ชื่อเล่น") || text.includes("name") || text.includes("ชื่อ") || text.includes("first") || text.includes("nick")) colName = i;
    // หา Slip
    else if (text.includes("สลิป") || text.includes("slip") || text.includes("หลักฐาน") || text.includes("upload") || text.includes("file") || text.includes("ไฟล์") || text.includes("รูป")) colSlip = i;
    // หา Timestamp
    else if (text.includes("timestamp") || text.includes("เวลา") || text.includes("date")) colTimestamp = i;
  });

  // Fallback
  if (colName === -1) colName = 3;
  if (colPhone === -1) colPhone = 5;
  if (colSlip === -1) colSlip = 8;
  
  let count = 0;
  for (let i = 1; i < data.length; i++) {
    const row = data[i];
    
    // ⏳ 1. กรองปี 2026 (ปี 69) เท่านั้น
    const rowDate = row[colTimestamp];
    if (rowDate instanceof Date) {
       if (rowDate.getFullYear() < 2026) {
          // ข้ามของเก่า
          continue;
       }
    }

    if (!row[colName]) continue; 

    // 🛡️ ป้องกัน Mapping ผิด (เอา Link หรือ เบอร์ มาเป็นชื่อ)
    const rawName = String(row[colName]);
    if (rawName.includes("http") || rawName.includes("www") || /^\d+$/.test(rawName)) {
       // ถ้าชื่อเป็น Link หรือ ตัวเลขล้วน -> สันนิษฐานว่า Map ผิด
       // console.log(`   ⏩ ข้าม row ${i+1}: ชื่อดูแปลกๆ (${rawName})`);
       continue;
    }

    const nickname = rawName;
    const phone = (colPhone >= 0 && row[colPhone]) ? String(row[colPhone]) : "No Phone";
    const slipUrl = (colSlip >= 0 && colSlip < row.length) ? String(row[colSlip]) : "";
    
    // ต้องมีสลิปและเป็นลิงก์ ถึงจะส่ง
    if (slipUrl && slipUrl.includes("http")) {
        
        // 1. 🔓 ปลดล็อคไฟล์ให้เป็น Public ก่อน
        setFilePublic(slipUrl);

        // 2. 🔍 ส่งไปตรวจกับ SlipOK
        let slipData = { amount: 0, transRef: `HISTORY_${sheet.getName().replace(/\s/g, '_')}_ROW${i+1}` }; // Default Ref
        let status = 'manual_check';
        let transferDate = "";
        let senderName = "";

        // ลองตรวจสลิป (เฉพาะถ้ายังไม่เคยตรวจ - แต่ในที่นี้เราถือว่าตรวจใหม่หมด)
        const checkResult = verifySlipDirectly(slipUrl);
        
        if (checkResult && checkResult.success) {
           // ✅ SlipOK บอกว่าผ่าน
           console.log(`      ✅ SlipOK Approved: ${nickname} (฿${checkResult.data.amount})`);
           status = 'verified';
           slipData = checkResult.data;
           transferDate = slipData.transTimestamp || "";
           senderName = slipData.sender?.name || "";
        } else {
           // ❌ SlipOK บอกว่าไม่ผ่าน หรือรูปดูไม่ออก หรือโควต้าเต็ม
           // console.log(`      ⚠️ SlipOK Manual Check needed for: ${nickname}`);
        }

       // 3. 🚀 ส่งข้อมูลเข้า Firestore
        syncToFirebasePayment({
          phoneNumber: phone,
          customerName: nickname,
          amount: slipData.amount || 0, 
          transRef: slipData.transRef || `HISTORY_MANUAL_${i+1}`, 
          senderName: senderName,
          transferDate: transferDate,
          status: status, // verified หรือ manual_check
          source: 'sync_history_all',
          slipUrl: slipUrl
        });
        
        count++;
        // พักหายใจหน่อย เดี๋ยว SlipOK/Firestore ด่า
        if (count % 3 === 0) Utilities.sleep(800); 
    } else {
       // สแปมเพิ่มคนที่ไม่มีสลิป ให้ขึ้นรอชำระ
       syncToFirebasePayment({
          phoneNumber: phone,
          customerName: nickname,
          amount: 0, 
          transRef: `NO_SLIP_${i+1}`, 
          senderName: "",
          transferDate: "",
          status: 'awaiting_payment',
          source: 'sync_history_all',
          slipUrl: ""
        });
        count++;
    }
  }
  
  if (count > 0) {
    console.log(`   ✅ ส่งข้อมูลจากชีท "${sheet.getName()}" สำเร็จ ${count} รายการ`);
  } else {
    // console.log(`   ⚠️ ชีท "${sheet.getName()}" ไม่พบรายการสลิปที่ถูกต้อง (Mapping: N=${colName},P=${colPhone},S=${colSlip})`);
  }
  
  return count;
}
