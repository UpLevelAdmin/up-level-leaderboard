/**
 * ทำให้ไฟล์เป็น Public (Anyone with the link) อัตโนมัติ
 */
function setFilePublic(fileUrl) {
  if (!fileUrl) return;
  try {
    const fileId = getFileIdFromUrl(fileUrl);
    if (fileId) {
      const file = DriveApp.getFileById(fileId);
      // ใช้ setSharing เพื่อเปิดสิทธิ์ Public Link ทันที
      file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
      console.log("🔓 Set Public Access for: " + fileId);
    }
  } catch (e) {
    console.warn("⚠️ Failed to set public access: " + e.toString());
  }
}

