      if (!hasError && syncedInFile > 0) {
        processedFiles.push(fileId);
        props.setProperty('PROCESSED_FILES', JSON.stringify(processedFiles));
        console.log(`✅ บันทึก Checkpoint สำเร็จ: ${file.getName()} (ส่งไป ${syncedInFile} รายการ)`);
