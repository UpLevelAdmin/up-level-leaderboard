// ฟังก์ชันดึง ID จากลิงก์ Google Drive ให้รองรับทุกรูปแบบ
function getFileIdFromUrl(url) {
  var id = "";
  // ลองหาแบบ ?id=...
  if (url.indexOf('?id=') > 0) {
    id = url.split('?id=')[1].split('&')[0];
  } else {
    // ลองหาแบบ /d/ID/ หรือ Pattern ID ทั่วไป (25+ ตัวอักษร)
    var parts = url.match(/[-\w]{25,}/);
    if (parts && parts.length > 0) {
      id = parts[0];
    }
  }
  return id;
}

function verifySlipDirectly(fileUrl) {
  if (!fileUrl) return null;
  
  try {
    const fileId = getFileIdFromUrl(fileUrl);
    if (!fileId) {
      console.error("❌ แกะ File ID ไม่ได้: " + fileUrl);
      return null;
    }

    const file = DriveApp.getFileById(fileId);
    const blob = file.getBlob();
    
    // Optional: ถ้าต้องการส่งรูปเป็น Base64 (ระวังโควต้า Firestore)
    // const base64Image = Utilities.base64Encode(blob.getBytes());
    
    const options = {
      method: "post",
      headers: {
        "x-authorization": SLIPOK_API_KEY,
        "Content-Type": "application/json"
      },
      payload: JSON.stringify({
        files: Utilities.base64Encode(blob.getBytes()),
        log: true
      }),
      muteHttpExceptions: true
    };
    
    const response = UrlFetchApp.fetch(`https://api.slipok.com/api/line/apikey/${BRANCH_ID}`, options);
    const result = JSON.parse(response.getContentText());
    
    // 💡 กรณีสลิปถูกต้อง (success: true)
    if (result.success) {
      return { success: true, data: result.data };
    }

    // 💡 กรณีสลิปซ้ำ (success: false แต่มี data) - ถือว่าผ่านเพราะเป็นสลิปจริงที่เคยส่งแล้ว
    // เช็คจาก code 1004 หรือ 1012 หรือข้อความ 'ใช้ไปแล้ว' / 'used' / 'สลิปซ้ำ'
    if (result.data && (result.code === 1004 || result.code === 1012 || result.message?.includes('ใช้ไปแล้ว') || result.message?.includes('used') || result.message?.includes('สลิปซ้ำ'))) {
      console.log("⚠️ สลิปซ้ำแต่ถูกต้อง (Duplicate Valid): " + fileUrl);
      return { success: true, data: result.data };
    }
    
    console.error(`❌ SlipOK Failed: ${result.message} (Code: ${result.code}) for ${fileUrl}`);

    return null;
  } catch (e) {
    console.error("Verify Error: " + e.toString() + " | URL: " + fileUrl);
    return null;
  }
}

